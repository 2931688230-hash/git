    if (sample_rate_hz != LLM_GATEWAY_AUDIO_SAMPLE_RATE) {
        return ESP_ERR_INVALID_ARG;
    }
    return llm_client_send_asr_pcm(pcm, samples);
}

esp_err_t llm_client_finish_voice_session(void)
