           (s_client.state == LLM_CLIENT_STATE_ASR_CONNECTING ||
            s_client.state == LLM_CLIENT_STATE_ASR_STREAMING ||
            s_client.state == LLM_CLIENT_STATE_ASR_FINISHING);
